# Supabase Configuration (Required)
# https://supabase.com 에서 프로젝트 생성 후 Settings > API에서 확인 가능
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# Firebase Configuration (Optional)
# https://console.firebase.google.com 에서 프로젝트 생성 후 웹 앱 추가하면 확인 가능
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Remote URLs (Production - Vercel)
# REMOTE1_URL=https://your-remote1.vercel.app
# REMOTE2_URL=https://your-remote2.vercel.app
# REMOTE3_URL=https://your-remote3.vercel.app
